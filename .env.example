# Copy this file to .env and fill in your values

# Root folder — all relative paths resolve from here.
# Defaults to the project directory (where config.py lives).
# Override to store photos/index/cache elsewhere, e.g.:
# ROOT_DIR=D:\MyFaceData
ROOT_DIR=

# Photo source: 'local' or 'onedrive'
SOURCE_TYPE=local

# Path to your local photos folder
LOCAL_PHOTOS_DIR=./photos

# OneDrive (only needed if SOURCE_TYPE=onedrive)
ONEDRIVE_CLIENT_ID=
ONEDRIVE_TENANT_ID=common
ONEDRIVE_FOLDER=/Pictures

# Index file location
INDEX_PATH=./data/face_index.npz

# Search tuning
SEARCH_THRESHOLD=0.35
MAX_RESULTS=20

# Server
HOST=0.0.0.0
PORT=8000

# Set to true to expose server via ngrok tunnel
TUNNEL_MODE=false
