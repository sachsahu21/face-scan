# ============================================================
#  Face Scan — Environment Configuration
#  Copy this file to .env and fill in your values.
#  All of these override config/config.yaml when set.
# ============================================================

# Where app artifacts are stored (index, token cache).
# Leave blank to use the project folder.
ROOT_DIR=

# Your photo collection — REQUIRED, no default.
PHOTOS_DIR=

# Sub-paths under ROOT_DIR (rarely need changing)
DATA_DIR=data
INDEX_PATH=data/face_index.npz
TOKEN_CACHE_PATH=data/.onedrive_token_cache.bin

# Photo source: 'local' or 'onedrive'
SOURCE_TYPE=local

# OneDrive (only needed when SOURCE_TYPE=onedrive)
ONEDRIVE_CLIENT_ID=
ONEDRIVE_TENANT_ID=common
ONEDRIVE_FOLDER=/Pictures

# Search tuning
SEARCH_THRESHOLD=0.35
MAX_RESULTS=20

# Server
HOST=0.0.0.0
PORT=8000
TUNNEL_MODE=false
