# ============================================================
#  Face Scan — Environment Configuration
#  Copy this file to .env and fill in your values.
#  Lines starting with # are comments and are ignored.
# ============================================================


# ------------------------------------------------------------
# ROOT DIRECTORY
# All subfolders below default to subdirectories of ROOT_DIR.
# Leave blank to use the project folder as the root.
# Example to store everything on an external drive:
#   ROOT_DIR=D:\FaceData
# ------------------------------------------------------------
ROOT_DIR=C:\\Users\\ISSUser\\Desktop\\Sachin\\hdd\\face_scan_artifacts


# ------------------------------------------------------------
# SOURCE PHOTOS  (required — no default)
# Point this to wherever your photos live. This is independent
# of ROOT_DIR and can change freely between runs.
# Examples:
#   PHOTOS_DIR=D:\Family\2024
#   PHOTOS_DIR=C:\Users\ISSUser\Pictures\Vacation
# ------------------------------------------------------------
PHOTOS_DIR=


# ------------------------------------------------------------
# APP ARTIFACTS  (all under ROOT_DIR — these rarely change)
# ------------------------------------------------------------
DATA_DIR=data
STATIC_DIR=static

# Face index file
INDEX_PATH=data/face_index.npz

# OneDrive token cache
TOKEN_CACHE_PATH=data/.onedrive_token_cache.bin


# ------------------------------------------------------------
# PHOTO SOURCE
# 'local'    → read photos from PHOTOS_DIR on disk
# 'onedrive' → read photos from OneDrive (requires credentials below)
# ------------------------------------------------------------
SOURCE_TYPE=local


# ------------------------------------------------------------
# ONEDRIVE  (only needed when SOURCE_TYPE=onedrive)
# 1. Register an app at portal.azure.com
# 2. Add permission: Microsoft Graph → Files.Read (delegated)
# 3. Set Client ID and Tenant ID here
# 4. Run: python scripts/onedrive_auth.py  (one-time login)
# ------------------------------------------------------------
ONEDRIVE_CLIENT_ID=
ONEDRIVE_TENANT_ID=common
ONEDRIVE_FOLDER=/Pictures


# ------------------------------------------------------------
# SEARCH TUNING
# SEARCH_THRESHOLD: 0.0–1.0  (higher = stricter, fewer results)
# MAX_RESULTS: maximum number of matches returned per search
# ------------------------------------------------------------
SEARCH_THRESHOLD=0.35
MAX_RESULTS=20


# ------------------------------------------------------------
# SERVER
# ------------------------------------------------------------
HOST=0.0.0.0
PORT=8000

# Set to true to expose the server via ngrok (outside local network)
TUNNEL_MODE=false
